        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"app\",container!=\"\",image!=\"\"}[5m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
