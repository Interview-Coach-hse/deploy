      "id": 1,
      "options": {
        "content": "Этот дашборд показывает инфраструктурные метрики по namespace `app` и базовые показатели pod PostgreSQL. Для полноценных внутренних метрик PostgreSQL (connections, locks, cache hit, transactions) нужен отдельный `postgres-exporter`.",
        "mode": "markdown"
      },
      "pluginVersion": "12.3.1",
      "title": "Notes",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "cores"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "options": {
        "legend": {
